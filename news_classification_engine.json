  "operational_guidelines": {
    "golden_rules": [
      "لا خبر يُنشر دون اكتمال جميع عناصر 5W1H",
      "المصدر غير الموثوق = رفض تلقائي",
      "التناقض مع معلومات مؤكدة = تعليق للنشر حتى التحقق",
      "الحرب المركبة يجب تصنيفها بدقة",
      "إعادة التصنيف متاحة دائمًا عند ظهور معلومات جديدة",
      "الحذف واجب عند ثبوت الخطأ",
      "كل عملية مسجلة في سجل التدقيق"
    ],
    
    "quality_metrics": {
      "accuracy_target": 0.95,
      "false_positive_max": 0.02,
      "false_negative_max": 0.03,
      "average_classification_time_seconds": 45,
      "manual_review_rate_target": 0.15
    }
  }

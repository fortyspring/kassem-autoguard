{
    "name": "osint-lb/osint-pro",
    "description": "OSINT Pro Plugin - Open Source Intelligence Analysis System",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "M.Kassem",
            "email": "osint@osint-lb.com"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/php-compatibility": "^9.3",
        "phpcompatibility/phpcompatibility-wp": "^2.1"
    },
    "autoload": {
        "psr-4": {
            "SO\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html tests/coverage/html",
        "test:ci": "phpunit --coverage-clover tests/coverage/clover.xml",
        "lint": "phpcs --standard=WordPress src/ includes/",
        "lint:fix": "phpcbf --standard=WordPress src/ includes/",
        "analyze": "phpstan analyze src/ includes/",
        "check": [
            "@lint",
            "@analyze",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
